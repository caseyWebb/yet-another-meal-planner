{
  "name": "yamp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "yamp monorepo: the yamp Cloudflare Worker (packages/worker), the runtime-agnostic shared contract (packages/contract), and the home-network satellite (packages/satellite).",
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*"
  ],
  "aube": {
    "allowBuilds": {
      "esbuild": true,
      "workerd": true,
      "@fission-ai/openspec": false,
      "@mongodb-js/zstd": false,
      "@parcel/watcher": false,
      "core-js-pure": false,
      "node-liblzma": false,
      "sharp": false
    }
  },
  "scripts": {
    "dev": "aube --filter @yamp/worker run dev",
    "dev:app": "node scripts/dev-app.mjs",
    "dev:admin": "node scripts/dev-admin.mjs",
    "deploy": "aube --filter @yamp/worker run deploy",
    "typecheck": "aube --recursive run typecheck",
    "test": "aube --filter @yamp/worker --filter @yamp/satellite --filter @yamp/admin-app --filter @yamp/widgets run test",
    "test:tooling": "aube --filter @yamp/worker run test:tooling",
    "test:admin": "aube --filter @yamp/worker run test:admin",
    "test:app": "aube --filter @yamp/worker run test:app",
    "check:licenses": "aube --filter @yamp/worker run check:licenses",
    "build:plugin": "aube --filter @yamp/worker run build:plugin",
    "build:admin": "aube --filter @yamp/admin-app run build",
    "build:app": "aube --filter @yamp/app run build",
    "build:widgets": "aube --filter @yamp/widgets run build",
    "build:vault": "aube --filter @yamp/worker run build:vault"
  },
  "devDependencies": {
    "@fission-ai/openspec": "^1.4.1"
  }
}
