{
  "name": "grocery-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "grocery-agent: the grocery-mcp Cloudflare Worker (MCP server) + the plugin-build and deploy tooling that data repos run via reusable CI workflows.",
  "engines": {
    "node": ">=22"
  },
  "aube": {
    "allowBuilds": {
      "esbuild": true,
      "workerd": true,
      "@fission-ai/openspec": false,
      "@mongodb-js/zstd": false,
      "core-js-pure": false,
      "node-liblzma": false,
      "sharp": false
    }
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:tooling": "node --test tests/build-plugin.test.mjs tests/merge-wrangler-config.test.mjs tests/stamp-readme-badge.test.mjs",
    "build:plugin": "node scripts/build-plugin.mjs --out plugin/grocery-agent",
    "build:plugin:dist": "node scripts/build-plugin.mjs",
    "build:admin": "node scripts/build-admin.mjs",
    "test:admin": "node scripts/test-admin.mjs"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.8.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "agents": "^0.16.2",
    "fast-xml-parser": "^5.9.3",
    "gray-matter": "^4.0.3",
    "jose": "^6.2.3",
    "js-yaml": "^5.0.0",
    "marked": "^18.0.5",
    "postal-mime": "^2.7.4",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260621.1",
    "@fission-ai/openspec": "^1.4.1",
    "@types/js-yaml": "^4.0.9",
    "json5": "^2.2.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.103.0"
  }
}
