{
  "name": "groceries-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "groceries-agent monorepo: the grocery-mcp Cloudflare Worker (packages/worker), the runtime-agnostic shared contract (packages/contract), and the home-network satellite (packages/satellite).",
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*"
  ],
  "aube": {
    "allowBuilds": {
      "esbuild": true,
      "workerd": true,
      "@fission-ai/openspec": false,
      "@mongodb-js/zstd": false,
      "core-js-pure": false,
      "node-liblzma": false,
      "sharp": false
    }
  },
  "scripts": {
    "dev": "aube --filter @grocery-agent/worker run dev",
    "deploy": "aube --filter @grocery-agent/worker run deploy",
    "typecheck": "aube --recursive run typecheck",
    "test": "aube --filter @grocery-agent/worker --filter @grocery-agent/satellite run test",
    "test:tooling": "aube --filter @grocery-agent/worker run test:tooling",
    "test:admin": "aube --filter @grocery-agent/worker run test:admin",
    "check:licenses": "aube --filter @grocery-agent/worker run check:licenses",
    "build:plugin": "aube --filter @grocery-agent/worker run build:plugin",
    "build:admin": "aube --filter @grocery-agent/worker run build:admin",
    "build:vault": "aube --filter @grocery-agent/worker run build:vault"
  },
  "devDependencies": {
    "@fission-ai/openspec": "^1.4.1"
  }
}
