{
  "name": "@grocery-agent/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared member-app UI: shadcn/ui primitives (vendored source) + the Tailwind v4 theme tokens translated from the committed design bundle. Raw-TS workspace exports — the consuming app's bundler compiles it.",
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": "./src/index.ts",
    "./theme.css": "./src/theme.css",
    "./cookbook.css": "./src/cookbook.css"
  },
  "types": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src",
    "format": "biome format --write src"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.6.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "oxlint": "^1.73.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3"
  }
}
