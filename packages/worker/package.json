{
  "name": "@yamp/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "yamp: the Cloudflare Worker (MCP server + operator admin panel) and the plugin/vault build tooling that data repos run via reusable CI workflows.",
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=22"
  },
  "exports": {
    "./api": "./src/api/app.ts",
    "./admin-api": "./src/admin/app.ts",
    "./order-shapes": "./src/order-shapes.ts"
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit && tsc --noEmit -p admin/visual/tsconfig.json && tsc --noEmit -p app/visual/tsconfig.json",
    "test": "vitest run",
    "test:tooling": "node --test tests/build-plugin.test.mjs tests/build-vault.test.mjs tests/merge-wrangler-config.test.mjs tests/navigate-denylist.test.mjs tests/stamp-readme-badge.test.mjs tests/strip-facets.test.mjs tests/check-licenses.test.mjs tests/source-hygiene.test.mjs",
    "check:licenses": "node scripts/check-licenses.mjs",
    "build:plugin": "node scripts/build-plugin.mjs",
    "build:vault": "node scripts/build-vault.mjs",
    "test:admin": "playwright test",
    "test:app": "playwright test -c playwright.app.config.ts"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.8.1",
    "@yamp/contract": "workspace:*",
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@simplewebauthn/server": "^13.3.2",
    "agents": "^0.17.1",
    "fast-xml-parser": "^5.9.3",
    "gray-matter": "^4.0.3",
    "hono": "^4.12.27",
    "jose": "^6.2.3",
    "js-yaml": "^5.0.0",
    "marked": "^18.0.5",
    "postal-mime": "^2.7.4",
    "ts-pattern": "^5.9.0",
    "uqr": "^0.1.3",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260621.1",
    "@playwright/test": "^1.61.1",
    "@types/js-yaml": "^4.0.9",
    "json5": "^2.2.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.103.0"
  }
}
