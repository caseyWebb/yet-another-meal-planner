# Worker-local build artifacts whose paths are anchored to this package.
# (Broad patterns — dist/, build/, .wrangler/, node_modules/, *.log, playwright-report/,
# test-results/, .dev.vars* — are matched by the repo-root .gitignore, which is unanchored.)

# The merged Workers Static Assets root (member-app-shell): the member SPA's
# index.html + hashed chunks (packages/app's vite build) AND the operator-admin
# island bundles + stylesheet under assets/admin/ (esbuild embeds env-specific paths).
assets/

# Playwright (admin + app visual/smoke harnesses) run outputs.
admin/visual/.results/
app/visual/.results/

# The app-ui suite's server-side member session, written as a Playwright storageState by
# app/visual/setup.mjs (app-ui-suite-deterministic-auth). Regenerated every run — never
# committed and never published as a CI artifact.
app/visual/.auth/

# Authoring vault: vendored community-plugin binaries (fetched on demand, sha256-verified),
# and the packaged distributable zip — kept out of the repo.
vault/.obsidian/plugins/*/main.js
vault/.obsidian/plugins/*/styles.css
grocery-authoring-vault*.zip
admin/visual/.screenshots/
app/visual/.screenshots/
