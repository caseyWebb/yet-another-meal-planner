{
  "name": "@grocery-agent/admin-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "The operator admin SPA (operator-admin): React 19 + Vite (Rolldown core) + TanStack Router/Query, served at /admin from the Worker's static-assets root. Builds into packages/worker/assets/admin/. No PWA/service worker — an online operator tool.",
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "oxlint src",
    "format": "biome format --write src"
  },
  "dependencies": {
    "@grocery-agent/ui": "workspace:*",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.17",
    "hono": "^4.12.27",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@cloudflare/workers-types": "^4.20260621.1",
    "@grocery-agent/worker": "workspace:*",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/router-plugin": "^1.168.19",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.73.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
