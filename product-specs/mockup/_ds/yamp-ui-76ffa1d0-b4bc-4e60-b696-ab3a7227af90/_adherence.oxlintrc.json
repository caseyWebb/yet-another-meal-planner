{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": [
          {
            "element": "button",
            "message": "Use <Button> from the design system instead of <button>."
          },
          {
            "element": "dialog",
            "message": "Use <Dialog> from the design system instead of <dialog>."
          },
          {
            "element": "input",
            "message": "Use <Input> from the design system instead of <input>."
          },
          {
            "element": "select",
            "message": "Use <Select> from the design system instead of <select>."
          },
          {
            "element": "input",
            "message": "Use <Slider> from the design system instead of <input>."
          },
          {
            "element": "table",
            "message": "Use <Table> from the design system instead of <table>."
          },
          {
            "element": "textarea",
            "message": "Use <Textarea> from the design system instead of <textarea>."
          }
        ]
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/actions/Button/**",
              "components/actions/RerollButton/**",
              "components/data/Card/**",
              "components/data/Pagination/**",
              "components/data/Table/**",
              "components/feedback/Alert/**",
              "components/feedback/Badge/**",
              "components/feedback/Empty/**",
              "components/feedback/EmptyState/**",
              "components/feedback/Progress/**",
              "components/feedback/Toaster/**",
              "components/forms/Combobox/**",
              "components/forms/Input/**",
              "components/forms/Label/**",
              "components/forms/NativeSelect/**",
              "components/forms/SegmentedControl/**",
              "components/forms/Select/**",
              "components/forms/Slider/**",
              "components/forms/Switch/**",
              "components/forms/Textarea/**",
              "components/forms/ToggleChip/**",
              "components/forms/TokenField/**",
              "components/icons/Icons/**",
              "components/meal-planning/FacetChip/**",
              "components/meal-planning/NightsStepper/**",
              "components/meal-planning/NudgeBar/**",
              "components/meal-planning/RecipeFacets/**",
              "components/meal-planning/SlotCard/**",
              "components/meal-planning/VarietyBar/**",
              "components/meal-planning/WeatherNoLocation/**",
              "components/meal-planning/WeatherStrip/**",
              "components/navigation/Crumbs/**",
              "components/navigation/GroupHeading/**",
              "components/navigation/PageHead/**",
              "components/overlays/AlertDialog/**",
              "components/overlays/Dialog/**",
              "components/overlays/DropdownMenu/**",
              "components/overlays/Tooltip/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Geist|Geist Mono))/i]",
        "message": "Font not provided by the design system. Available: Geist, Geist Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute > JSXIdentifier[name!=/^(?:ref|className|id|style|children|variant|key|ref|className|style|children)$/]",
        "message": "<Alert> doesn't accept that prop. Declared props: ref, className, id, style, children, variant."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|destructive)$/]",
        "message": "<Alert> variant must be one of 'default' | 'destructive'."
      },
      {
        "selector": "JSXOpeningElement[name.name='AlertDialog'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|open|defaultOpen|key|ref|className|style|children)$/]",
        "message": "<AlertDialog> doesn't accept that prop. Declared props: children, open, defaultOpen."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:ref|className|id|style|children|variant|asChild|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: ref, className, id, style, children, variant, asChild."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|destructive|secondary|outline)$/]",
        "message": "<Badge> variant must be one of 'default' | 'destructive' | 'secondary' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:ref|className|id|style|children|variant|size|asChild|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: ref, className, id, style, children, variant, size, asChild."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:link|default|destructive|secondary|outline|ghost)$/]",
        "message": "<Button> variant must be one of 'link' | 'default' | 'destructive' | 'secondary' | 'outline' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:default|sm|lg|icon)$/]",
        "message": "<Button> size must be one of 'default' | 'sm' | 'lg' | 'icon'."
      },
