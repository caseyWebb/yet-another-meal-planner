# Dependencies
node_modules
.pnp
.pnp.js

# Build output
dist/
build/
*.tsbuildinfo
# packages/worker/assets/ (the merged static-assets root: the member SPA + the
# operator-admin islands/stylesheet under assets/admin/) is a BUILD ARTIFACT —
# generated by packages/app's vite build + scripts/build-admin.mjs, built fresh at
# CI/deploy time (and for local `wrangler dev`), never committed. The esbuild bundles
# embed environment-specific module paths (the aube virtual-store location), so a
# committed copy isn't reproducible across machines. Ignored by the worker package's
# own .gitignore (assets/); the SPA's hashed chunks land under assets/assets/.

# Playwright (the admin-ui + app-ui harnesses): run outputs, the HTML report, and the
# per-area review screenshots are artifacts — no pixel baselines are committed (the CI
# gates are functional; screenshots are published on UI PRs — see admin/visual/README.md).
admin/visual/.results/
app/visual/.results/
app/visual/.screenshots/
playwright-report/
blob-report/
test-results/

# Cloudflare Worker / Wrangler
.wrangler/
.dev.vars
.dev.vars.*
!.dev.vars.example
wrangler.toml.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment / secrets
.env
.env.*
!.env.example
# Machine-local mise env (e.g. YAMP_MCP_URL for the plugin build) — never committed
mise.local.toml
.mise.local.toml
# Private keys (e.g. the GitHub App PKCS#8 key used for `wrangler secret put`) —
# NEVER commit. The key belongs in Cloudflare secrets only.
*.pem
*.key

