# Dependencies
node_modules/
.pnp
.pnp.js

# Build output
dist/
build/
# generated by scripts/build-site.mjs; built in CI, never committed
site/
*.tsbuildinfo
# The operator-admin SPA bundle IS committed (served by the Worker's ASSETS binding) —
# re-include it despite the broad dist/ rule above (generated by scripts/build-admin.mjs).
!admin/dist/
!admin/dist/**
# Elm compiler cache (admin/) — never committed.
admin/elm-stuff/

# Cloudflare Worker / Wrangler
.wrangler/
.dev.vars
.dev.vars.*
!.dev.vars.example
wrangler.toml.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment / secrets
.env
.env.*
!.env.example
# Machine-local mise env (e.g. GROCERY_MCP_URL for the plugin build) — never committed
mise.local.toml
.mise.local.toml
# Private keys (e.g. the GitHub App PKCS#8 key used for `wrangler secret put`) —
# NEVER commit. The key belongs in Cloudflare secrets only.
*.pem
*.key

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# Editors
.vscode/
.idea/
*.swp
*.swo
*~
.\#*
\#*\#
.migration/
