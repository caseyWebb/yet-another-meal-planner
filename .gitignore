# Dependencies
node_modules/
.pnp
.pnp.js

# Build output
dist/
build/
*.tsbuildinfo
# admin/dist/ (the operator-admin island bundles + stylesheet) is a BUILD ARTIFACT —
# generated by scripts/build-admin.mjs and built fresh at CI/deploy time (and for local
# `wrangler dev`), never committed. The esbuild bundles embed environment-specific module
# paths (the aube virtual-store location), so a committed copy isn't reproducible across
# machines. Falls under the broad dist/ rule above.

# Authoring vault: the committed vault/ holds the generated config + pinned plugin
# manifests, but the heavy plugin bundles are vendored on demand by
# `build-vault --fetch-plugins` (sha256-verified from vault-template/plugin-pins.json)
# — keep the multi-MB third-party binaries out of the public repo.
vault/.obsidian/plugins/*/main.js
vault/.obsidian/plugins/*/styles.css
# Packaged distributable (the zip an author downloads).
grocery-authoring-vault*.zip

# Playwright (admin visual/smoke harness): run outputs + the HTML report are artifacts. The
# committed baselines under admin/visual/admin.spec.ts-snapshots/ are kept (a dev bootstrap — see
# admin/visual/README.md; CI's pinned Chromium differs, so the CI job is non-blocking).
admin/visual/.results/
playwright-report/
blob-report/
test-results/

# Cloudflare Worker / Wrangler
.wrangler/
.dev.vars
.dev.vars.*
!.dev.vars.example
wrangler.toml.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment / secrets
.env
.env.*
!.env.example
# Machine-local mise env (e.g. GROCERY_MCP_URL for the plugin build) — never committed
mise.local.toml
.mise.local.toml
# Private keys (e.g. the GitHub App PKCS#8 key used for `wrangler secret put`) —
# NEVER commit. The key belongs in Cloudflare secrets only.
*.pem
*.key

